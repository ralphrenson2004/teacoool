<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8E8E8">

    <!-- Header with Logo -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerHorizontal="true"
            android:src="@drawable/logo"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Logo" />
    </RelativeLayout>

    <!-- Navigation Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingVertical="12dp"
        android:gravity="center"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tabMenu"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Menu"
            android:textSize="14sp"
            android:textColor="#666666"
            android:textAlignment="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/tabFeatured"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Featured"
            android:textSize="14sp"
            android:textColor="#666666"
            android:textAlignment="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/tabPrevious"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Previous"
            android:textSize="14sp"
            android:textColor="#8B4513"
            android:textStyle="bold"
            android:textAlignment="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/tabFavorites"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Favorites"
            android:textSize="14sp"
            android:textColor="#666666"
            android:textAlignment="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Order Confirmed Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order Confirmed"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="16dp"/>

            <!-- Order Items Container -->
            <LinearLayout
                android:id="@+id/orderItemsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">
                <!-- Order items will be added here dynamically -->
            </LinearLayout>

            <!-- Track Order Button -->
            <Button
                android:id="@+id/btnTrackOrder"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Track Order"
                android:backgroundTint="#00FF00"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="16dp"/>

            <!-- Thank You Message -->
            <TextView
                android:id="@+id/tvThankYouMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thank you for your order! Please hang tight; your drinks will be arriving shortly."
                android:textSize="14sp"
                android:textColor="#00AA00"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="24dp"/>

            <!-- Order Status Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <!-- Order Processing -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_order_processing"
                        android:tint="#00FF00"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order"
                        android:textSize="12sp"
                        android:textColor="#000000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Processing"
                        android:textSize="12sp"
                        android:textColor="#000000"/>

                    <TextView
                        android:id="@+id/tvOrderTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="11:58:50 pm"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- Dashed Line -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    android:layout_height="wrap_content"
                    android:text="- - -"
                    android:textAlignment="center"
                    android:textColor="#CCCCCC"/>

                <!-- Delivery -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_directions"
                        android:tint="#CCCCCC"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery"
                        android:textSize="12sp"
                        android:textColor="#999999"/>

                </LinearLayout>

                <!-- Dashed Line -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="0.5"
                    android:layout_height="wrap_content"
                    android:text="- - -"
                    android:textAlignment="center"
                    android:textColor="#CCCCCC"/>

                <!-- Complete -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="#CCCCCC"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete"
                        android:textSize="12sp"
                        android:textColor="#999999"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>
    <include layout="@layout/footer_layout" />
</LinearLayout>